# Optional telemetry toggle.
VITE_ENABLE_TELEMETRY=false

# Optional app version tag for event properties
VITE_APP_VERSION=dev

# Google OAuth (required for web auth and MCP OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=
GOOGLE_ALLOWED_DOMAIN=cultivarium.org

# Public URL (required for MCP OAuth callbacks)
PUBLIC_URL=https://agentdoc.up.railway.app
